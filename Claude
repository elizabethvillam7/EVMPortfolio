  <!-- FEATURED PROJECT -->
  <section id="projects">
    <div class="section-header">
      <span class="section-label">Featured Project</span>
      <div class="section-line"></div>
    </div>

    <div class="featured-project">
      <div class="project-header">
        <div class="project-meta">
          <div class="project-type">Voice of the Customer Initiative</div>
          <h3>Customer Onboarding Redesign</h3>
          <div class="project-org">Redi Carpet &nbsp;|&nbsp; Cross-Functional Program</div>
        </div>
        <div class="project-number">01</div>
      </div>
      <div class="project-body">
        <p class="project-overview">
          Led a formal, end-to-end initiative to redesign the customer onboarding experience using Voice of the Customer data. The program spanned four project phases, engaged stakeholders across Sales, Operations, and Customer Support, and delivered measurable improvements in speed, satisfaction, and process adherence.
        </p>

        <div class="phases">
          <div class="phase">
            <div class="phase-label">Initiation</div>
            <div class="phase-text">Analyzed VoC data from surveys, call transcripts, and support tickets. Identified pain points, developed project charter, and aligned cross-functional stakeholders.</div>
          </div>
          <div class="phase">
            <div class="phase-label">Planning</div>
            <div class="phase-text">Mapped the current onboarding workflow end to end, performed a gap analysis, and designed a future-state process prioritizing simplification and automation.</div>
          </div>
          <div class="phase">
            <div class="phase-label">Execution</div>
            <div class="phase-text">Consolidated multiple intake forms into a single digital experience, standardized onboarding checklists, implemented automated milestone communications, and led training and change management.</div>
          </div>
          <div class="phase">
            <div class="phase-label">Monitoring &amp; Close</div>
            <div class="phase-text">Tracked KPIs including cycle time, CSAT scores, and support ticket volume. Made iterative adjustments, documented final processes, and transitioned ownership to operations.</div>
          </div>
        </div>

        <div class="results-grid">
          <div class="result-card">
            <div class="result-num">42%</div>
            <div class="result-desc">Reduction in onboarding cycle time</div>
          </div>
          <div class="result-card">
            <div class="result-num">28%</div>
            <div class="result-desc">Increase in first-month customer satisfaction</div>
          </div>
          <div class="result-card">
            <div class="result-num">35%</div>
            <div class="result-desc">Decrease in onboarding-related support tickets</div>
          </div>
          <div class="result-card">
            <div class="result-num">95%</div>
            <div class="result-desc">Internal process adherence achieved</div>
          </div>
        </div>

        <div class="project-skills">
          <span class="tag">VoC Analysis</span>
          <span class="tag">Process Mapping</span>
          <span class="tag">Gap Analysis</span>
          <span class="tag">Change Management</span>
          <span class="tag">KPI Tracking</span>
          <span class="tag">Stakeholder Alignment</span>
          <span class="tag">Cross-Functional Leadership</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ADDITIONAL PROJECTS -->
  <section style="padding-top: 0;">
    <div class="section-header">
      <span class="section-label">Additional Projects</span>
      <div class="section-line"></div>
    </div>
    <div class="additional-grid">

      <div class="mini-project">
        <div class="mini-type">Process Improvement</div>
        <div class="mini-title">QA &amp; Escalation Reduction Initiative</div>
        <div class="mini-date">Redi Carpet &nbsp;|&nbsp; Sep 2025 &ndash; Dec 2025</div>
        <p class="mini-desc">Built and launched a QA audit program across 13+ regional branches, standardizing response workflows and introducing root cause analysis processes to reduce recurring escalations.</p>
        <div class="mini-result">25% reduction in customer escalations within one year</div>
      </div>

      <div class="mini-project">
        <div class="mini-type">Operations</div>
