<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Elizabeth Villa Montes | Project Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #E8E4DF;
      --warm-white: #F0EDE9;
      --clay: #8B1A35;
      --clay-light: #B5627A;
      --clay-dark: #6B0F25;
      --charcoal: #1C1C1C;
      --mid: #7A6A63;
      --light-line: #D8D2CB;
      --tag-bg: #E4DDD6;
    }

    html { scroll-behavior: smooth; }

    body {
      background-color: var(--cream);
      color: var(--charcoal);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      line-height: 1.7;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: rgba(250, 247, 242, 0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--light-line);
      padding: 0 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      height: 60px;
    }

    .nav-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--charcoal);
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      text-decoration: none;
      color: var(--mid);
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--clay); }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 6rem 4rem 4rem;
      max-width: 900px;
      margin: 0 auto;
      position: relative;
    }

    .hero-eyebrow {
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--clay);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .hero-eyebrow::before {
      content: '';
      display: block;
      width: 32px;
      height: 1px;
      background: var(--clay);
    }

    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 600;
      line-height: 1.05;
      color: var(--charcoal);
      margin-bottom: 1.5rem;
    }

    h1 em {
      font-style: italic;
      color: var(--clay);
    }

    .hero-sub {
      font-size: 1.05rem;
      color: var(--mid);
      max-width: 540px;
      line-height: 1.8;
      margin-bottom: 2.5rem;
    }

    .hero-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .tag {
      background: var(--tag-bg);
      color: var(--mid);
      padding: 0.3rem 0.85rem;
      border-radius: 999px;
      font-size: 0.75rem;
      letter-spacing: 0.04em;
    }

    /* STATS BAR */
    .stats-bar {
      background: var(--charcoal);
      color: var(--cream);
      padding: 3rem 4rem;
    }

    .stats-inner {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      text-align: center;
    }

    .stat-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.8rem;
      font-weight: 600;
      color: var(--clay-light);
      line-height: 1;
    }

    .stat-label {
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(250,247,242,0.55);
      margin-top: 0.4rem;
    }

    /* SECTIONS */
    section {
      padding: 5rem 4rem;
      max-width: 900px;
      margin: 0 auto;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 3rem;
    }

    .section-label {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--clay);
    }

    .section-line {
      flex: 1;
      height: 1px;
      background: var(--light-line);
    }

    h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 600;
      color: var(--charcoal);
      margin-bottom: 0.5rem;
      line-height: 1.2;
    }

    /* FEATURED PROJECT */
    .featured-project {
      background: var(--warm-white);
      border: 1px solid var(--light-line);
      border-radius: 4px;
      overflow: hidden;
      margin-bottom: 2rem;
      transition: box-shadow 0.3s;
    }

    .featured-project:hover {
      box-shadow: 0 8px 40px rgba(44,40,37,0.08);
    }

    .project-header {
      padding: 2.5rem 2.5rem 0;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .project-number {
      font-family: 'Cormorant Garamond', serif;
      font-size: 4rem;
      font-weight: 400;
      color: var(--light-line);
      line-height: 1;
      user-select: none;
    }

    .project-meta {
      flex: 1;
    }

    .project-type {
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--clay);
      margin-bottom: 0.5rem;
    }

    h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 600;
      color: var(--charcoal);
      line-height: 1.2;
      margin-bottom: 0.25rem;
    }

    .project-org {
      font-size: 0.82rem;
      color: var(--mid);
    }

    .project-body {
      padding: 1.5rem 2.5rem 2.5rem;
    }

    .project-overview {
      color: var(--mid);
      font-size: 0.92rem;
      line-height: 1.8;
      margin-bottom: 2rem;
      border-left: 2px solid var(--clay-light);
      padding-left: 1.25rem;
    }

    /* PHASES */
    .phases {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .phase {
      background: var(--tag-bg);
      border-radius: 4px;
      padding: 1.1rem 1.25rem;
    }

    .phase-label {
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--clay-dark);
      margin-bottom: 0.4rem;
    }

    .phase-text {
      font-size: 0.82rem;
      color: var(--charcoal);
      line-height: 1.5;
    }

    /* RESULTS */
    .results-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .result-card {
      background: var(--charcoal);
      color: var(--cream);
      border-radius: 4px;
      padding: 1.25rem;
      text-align: center;
    }

    .result-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.2rem;
      font-weight: 600;
      color: var(--clay-light);
      line-height: 1;
    }

    .result-desc {
      font-size: 0.72rem;
      letter-spacing: 0.04em;
      color: rgba(250,247,242,0.6);
      margin-top: 0.35rem;
      line-height: 1.4;
    }

    .project-skills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    /* ADDITIONAL PROJECTS */
    .additional-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
    }

    .mini-project {
      background: var(--warm-white);
      border: 1px solid var(--light-line);
      border-radius: 4px;
      padding: 1.75rem;
      transition: box-shadow 0.3s, transform 0.3s;
    }

    .mini-project:hover {
      box-shadow: 0 6px 30px rgba(44,40,37,0.07);
      transform: translateY(-2px);
    }

    .mini-type {
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--clay);
      margin-bottom: 0.6rem;
    }

    .mini-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--charcoal);
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }

    .mini-date {
      font-size: 0.75rem;
      color: var(--mid);
      margin-bottom: 0.85rem;
    }

    .mini-desc {
      font-size: 0.85rem;
      color: var(--mid);
      line-height: 1.7;
      margin-bottom: 1.1rem;
    }

    .mini-result {
      font-size: 0.8rem;
      color: var(--clay-dark);
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .mini-result::before {
      content: '';
      display: block;
      width: 18px;
      height: 1px;
      background: var(--clay);
    }

    /* SKILLS */
    .skills-section {
      background: var(--warm-white);
      border-top: 1px solid var(--light-line);
      padding: 5rem 4rem;
    }

    .skills-inner {
      max-width: 900px;
      margin: 0 auto;
    }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
      margin-top: 2.5rem;
    }

    .skill-group h4 {
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--clay);
      margin-bottom: 0.85rem;
    }

    .skill-group ul {
      list-style: none;
    }

    .skill-group li {
      font-size: 0.87rem;
      color: var(--mid);
      padding: 0.3rem 0;
      border-bottom: 1px solid var(--light-line);
      line-height: 1.4;
    }

    /* CONTACT */
    .contact-section {
      background: var(--charcoal);
      padding: 5rem 4rem;
      text-align: center;
    }

    .contact-inner {
      max-width: 600px;
      margin: 0 auto;
    }

    .contact-eyebrow {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--clay-light);
      margin-bottom: 1.5rem;
    }

    .contact-heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 5vw, 3.5rem);
      color: var(--cream);
      font-weight: 600;
      line-height: 1.15;
      margin-bottom: 1rem;
    }

    .contact-heading em {
      font-style: italic;
      color: var(--clay-light);
    }

    .contact-sub {
      font-size: 0.9rem;
      color: rgba(250,247,242,0.55);
      margin-bottom: 2.5rem;
      line-height: 1.8;
    }

    .contact-links {
      display: flex;
      justify-content: center;
      gap: 1.25rem;
      flex-wrap: wrap;
    }

    .contact-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.8rem 1.75rem;
      border-radius: 2px;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.2s;
    }

    .contact-btn.primary {
      background: var(--clay);
      color: var(--cream);
    }

    .contact-btn.primary:hover {
      background: var(--clay-dark);
    }

    .contact-btn.secondary {
      border: 1px solid rgba(250,247,242,0.25);
      color: var(--cream);
    }

    .contact-btn.secondary:hover {
      border-color: var(--clay-light);
      color: var(--clay-light);
    }

    footer {
      background: var(--charcoal);
      border-top: 1px solid rgba(250,247,242,0.08);
      text-align: center;
      padding: 1.5rem;
      font-size: 0.75rem;
      color: rgba(250,247,242,0.3);
      letter-spacing: 0.06em;
    }

    /* ANIMATIONS */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .hero > * {
      animation: fadeUp 0.7s ease both;
    }

    .hero > *:nth-child(1) { animation-delay: 0.1s; }
    .hero > *:nth-child(2) { animation-delay: 0.25s; }
    .hero > *:nth-child(3) { animation-delay: 0.4s; }
    .hero > *:nth-child(4) { animation-delay: 0.55s; }

    /* RESPONSIVE */
    @media (max-width: 640px) {
      nav { padding: 0 1.25rem; }
      .nav-links { gap: 1rem; }
      .hero, section { padding: 5rem 1.5rem 3rem; }
      .stats-bar { padding: 2.5rem 1.5rem; }
      .stats-inner { grid-template-columns: repeat(2, 1fr); }
      .project-header { padding: 1.75rem 1.75rem 0; }
      .project-body { padding: 1.25rem 1.75rem 1.75rem; }
      .skills-section { padding: 3rem 1.5rem; }
      .contact-section { padding: 3.5rem 1.5rem; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <span class="nav-name">Elizabeth Villa Montes</span>
    <ul class="nav-links">
      <li><a href="#projects">Projects</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#contact">Contact</a></li>
